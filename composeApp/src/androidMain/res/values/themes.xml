<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="NightAdjusted.Theme.Matsumo" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="PlatformAdjusted.Theme.Matsumo" parent="NightAdjusted.Theme.Matsumo">
        <item name="android:statusBarColor">#000</item>
    </style>

    <!-- The final theme we use -->
    <style name="Theme.Matsumo" parent="PlatformAdjusted.Theme.Matsumo">
        <!-- Mapbox turn icon drawables (mapbox_ic_*) reference these theme attributes.
             Without them, fillColor resolves to transparent and the arrows are invisible.
             The value here is only a base fill; Compose ColorFilter.tint overrides it at render time. -->
        <item name="maneuverTurnIconColor">@android:color/white</item>
        <item name="maneuverTurnIconShadowColor">#59FFFFFF</item>
    </style>

    <style name="NightAdjusted.Theme.Splash" parent="Theme.SplashScreen">
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Matsumo.Splash" parent="NightAdjusted.Theme.Splash">
        <item name="postSplashScreenTheme">@style/Theme.Matsumo</item>
    </style>

</resources>
